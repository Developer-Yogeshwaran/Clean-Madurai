rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      return request.auth != null && firestore.get(/databases/(default)/documents/Users/$(request.auth.uid)).data.role == 'admin';
    }

    // Allow users to upload to their own Uploads folder
    match /Uploads/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users to upload to PublicReports folder
    match /PublicReports/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Certificates can only be written by Cloud Functions/Admin, but read by the owner or admin
    match /certificates/{fileName} {
      // Filename convention is {userId}_{level}.pdf
      allow read: if true; // Verification links are public
      allow write: if false; // Only admin/backend
    }
  }
}
